{
  "name": "casperengelmann.com",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "vendor/emdash/packages/*"
  ],
  "scripts": {
    "bootstrap": "bun --bun emdash init",
    "build": "bun --bun astro build",
    "dev": "bun --bun astro dev",
    "migrate:emdash": "bun --bun scripts/migrate-astro-content-to-emdash.mjs",
    "predeploy": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun --bun ./dist/server/entry.mjs",
    "type-check": "bun --bun astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/node": "10.0.4",
    "@astrojs/react": "^5.0.3",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "astro": "6.1.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.12",
    "effect": "^3.21.0",
    "emdash": "workspace:*",
    "ms": "^2.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^4.7.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/kumo": "^1.16.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bun": "^1.3.11",
    "@types/ms": "^0.7.34",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unicorn": "^52.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.13",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11",
  "volta": {
    "node": "22.12.0"
  },
  "emdash": {
    "seed": ".emdash/seed.json"
  }
}
