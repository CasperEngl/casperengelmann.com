    "vitest": "^4.0.18"
  },
  "workspaces": [
    "vendor/emdash/packages/*"
  ],
  "scripts": {
    "bootstrap": "bun --bun emdash init",
    "build:vendor": "bun --bun run --cwd vendor/emdash/packages/blocks build && bun --bun run --cwd vendor/emdash/packages/auth build && bun --bun run --cwd vendor/emdash/packages/gutenberg-to-portable-text build && bun --bun run --cwd vendor/emdash/packages/admin build && bun --bun run --cwd vendor/emdash/packages/core build",
    "build": "bun --bun run build:vendor && bun --bun astro build",
    "dev": "bun --bun run build:vendor && bun --bun astro dev",
    "migrate:emdash": "bun scripts/migrate-astro-content-to-emdash.mjs",
    "predeploy": "bun --bun run build",
    "preview": "bun --bun run build:vendor && bun --bun astro preview",
    "start": "bun ./dist/server/entry.mjs",
    "type-check:vendor": "bun --bun run --cwd vendor/emdash/packages/blocks typecheck && bun --bun run --cwd vendor/emdash/packages/auth typecheck && bun --bun run --cwd vendor/emdash/packages/gutenberg-to-portable-text typecheck && bun --bun run --cwd vendor/emdash/packages/admin typecheck && bun --bun run --cwd vendor/emdash/packages/core typecheck",
    "type-check": "bun --bun run type-check:vendor && bun --bun run build:vendor && bun --bun astro check"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/node": "10.0.4",
    "@astrojs/react": "^5.0.3",
    "@emdash-cms/admin": "workspace:*",
    "@emdash-cms/auth": "workspace:*",
    "@emdash-cms/blocks": "workspace:*",
    "@emdash-cms/gutenberg-to-portable-text": "workspace:*",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "astro": "6.1.4",
    "better-sqlite3": "catalog:",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.12",
    "effect": "^3.21.0",
    "emdash": "workspace:*",
    "ms": "^2.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^4.7.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/kumo": "^1.16.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/babel__core": "^7.20.5",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bun": "catalog:",
    "@types/ms": "^0.7.34",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unicorn": "^52.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.13",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11",
  "volta": {
    "node": "22.12.0"
  },
  "emdash": {
    "seed": ".emdash/seed.json"
  }
}
