---
import { getEmDashCollection } from 'emdash'
import Section from '~/components/layout/section.astro'
import OutboundLink from '~/components/ui/outbound-link.astro'

interface Props {
  title: string
}

const { title } = Astro.props

const { entries: projects } = await getEmDashCollection('projects', {
  status: 'published',
  orderBy: {
    created_at: 'desc',
  },
})
---

<Section title={title}>
  <ul class="list-['-'] list-inside space-y-2 marker:text-neutral-400 dark:marker:text-neutral-500">
    {
      projects.map((project) => (
        <li>
          <div class="inline-block align-top">
            <OutboundLink href={project.data.link}>{project.data.title}</OutboundLink>
            <p class="text-neutral-500 dark:text-neutral-400 text-sm">{project.data.description}</p>
          </div>
        </li>
      ))
    }
  </ul>
</Section>
