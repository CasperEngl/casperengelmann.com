---
import { getEmDashCollection } from 'emdash'
import { PortableText } from 'emdash/ui'
import Section from '~/components/layout/section.astro'
import JobExperience from '~/components/ui/job-experience.astro'

interface Props {
  title: string
}

const { title } = Astro.props

const { entries: experiences } = await getEmDashCollection('experience', {
  status: 'published',
  orderBy: {
    start_date: 'desc',
  },
})
---

<Section
  title={title}
  class="divide-y divide-neutral-100 dark:divide-neutral-700"
>
  {
    experiences.map((experience, index) => {
      return (
        <div class="py-4">
          <JobExperience
            company={experience.data.company}
            role={experience.data.role}
            link={experience.data.link}
            startDate={experience.data.start_date}
            endDate={experience.data.end_date}
          />
          <div class="mt-2 text-neutral-600 dark:text-neutral-300">
            <PortableText value={experience.data.body} />
          </div>
        </div>
      )
    })
  }
</Section>
